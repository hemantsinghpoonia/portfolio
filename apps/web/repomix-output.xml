    align-items: center;
    justify-content: space-between;
    height: var(--site-topbar-height);
    padding-inline: 1rem;
    background: color-mix(in oklch, var(--surface) 84%, transparent);
    border-block-end: 1px solid
      color-mix(in oklch, var(--outline-variant) 10%, transparent);
    backdrop-filter: blur(12px);
  }

  .mobile-menu-sheet {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    justify-content: center;
    padding-top: var(--site-topbar-height);
    background: var(--surface);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
    color: var(--foreground);
  }

  .section-kicker {
    color: var(--brand);
    font-size: var(--text-label-sm);
    font-family: var(--font-body);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bento-card {
    background: var(--surface-container-lowest);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    padding: 2rem;
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease,
      background-color 0.3s ease;
  }

  .bento-card:hover {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--border-subtle-strong);
  }

  .bento-card-muted {
    background: var(--surface-container-low);
  }

  .nav-link {
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: -0.2rem;
    height: 1px;
    background-color: var(--brand);
    transform: scaleX(0);
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .nav-link:hover::after,
  .nav-link-active::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .nav-link-active {
    color: var(--brand);
    font-weight: 600;
  }

  .code-window {
    position: relative;
    overflow: hidden;
    background: var(--primary-strong);
    color: var(--inverse-foreground);
    border: 1px solid
      color-mix(in oklch, var(--inverse-foreground) 10%, transparent);
    border-radius: var(--radius-card);
    padding: 1rem;
  }

  .code-window::before {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 0.25rem;
    background: var(--brand);
  }

  .code-window__chrome {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .code-window__dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
  }

  .code-window__dot--red {
    background: #ef4444;
  }

  .code-window__dot--yellow {
    background: #f59e0b;
  }

  .code-window__dot--green {
    background: #22c55e;
  }

  .code-token-keyword {
    color: var(--brand-strong);
  }

  .code-token-property {
    color: color-mix(in oklch, var(--primary-fixed-dim) 84%, white 16%);
  }

  .code-token-string {
    color: var(--brand-fixed-dim);
  }

  .code-token-comment {
    color: color-mix(in oklch, var(--inverse-foreground) 60%, transparent);
  }

  .field-label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .field-control {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid
      color-mix(in oklch, var(--foreground) 20%, transparent);
    border-radius: 0;
    padding-inline: 0;
    padding-block: 0.5rem;
    color: var(--foreground);
    transition:
      border-color 0.2s ease,
      border-width 0.2s ease;
  }

  .field-control::placeholder {
    color: color-mix(in oklch, var(--muted-foreground) 70%, transparent);
  }

  .field-control:focus {
    outline: none;
    border-bottom-width: 2px;
    border-bottom-color: var(--brand);
  }

  .btn-primary {
    background: var(--foreground);
    color: var(--background);
    border: 1px solid transparent;
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .btn-primary:hover {
    background: var(--brand);
    color: var(--brand-foreground);
  }

  .btn-secondary {
    background: transparent;
    color: var(--foreground);
    border: 1px solid var(--foreground);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .btn-secondary:hover {
    background: color-mix(in oklch, var(--surface) 50%, transparent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--muted-foreground);
    border: 1px solid transparent;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .btn-ghost:hover {
    background: var(--surface-container-low);
    color: var(--foreground);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-chip);
    border: 1px solid
      color-mix(in oklch, var(--outline-variant) 20%, transparent);
    background: var(--surface-container-low);
    color: var(--muted-foreground);
    padding-inline: 0.75rem;
    padding-block: 0.375rem;
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    line-height: 1;
  }

  .chip-outline {
    background: var(--surface-container-lowest);
  }

  .separator-line {
    height: 1px;
    width: 100%;
    background: color-mix(in oklch, var(--outline-variant) 20%, transparent);
  }

  .blog-carousel-track,
  .no-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .blog-carousel-track::-webkit-scrollbar,
