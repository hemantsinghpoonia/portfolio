@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  body {
    background-color: var(--background);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    color: var(--foreground);
    overflow-x: hidden;
    scroll-behavior: smooth;
  }

  html {
    @apply font-sans;
    overflow-x: clip;
  }

  h1,
  h2,
  h3,
  h4,
  .font-display {
    font-family: var(--font-display);
  }
}

@layer components {
  .app-shell {
    max-width: var(--layout-container-max);
    margin-inline: auto;
    padding-inline: var(--layout-margin-mobile);
    padding-top: var(--layout-main-top-mobile);
    padding-bottom: 8rem;
  }

  @media (min-width: 768px) {
    .app-shell {
      margin-left: var(--layout-sidebar-mobile);
      padding-inline: var(--layout-margin-desktop);
      padding-top: var(--layout-main-top-desktop);
    }
  }

  @media (min-width: 1024px) {
    .app-shell {
      margin-left: var(--layout-sidebar-desktop);
    }
  }

  @media (min-width: 1280px) {
    .app-shell {
      margin-left: var(--layout-sidebar-wide);
    }
  }

  .site-sidebar {
    position: fixed;
    inset-block: 0;
    inset-inline-start: 0;
    z-index: 50;
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: var(--layout-sidebar-mobile);
    padding: 2.5rem 0.75rem;
    background: color-mix(in oklch, var(--surface) 80%, transparent);
    border-inline-end: 1px solid
      color-mix(in oklch, var(--outline-variant) 10%, transparent);
    backdrop-filter: blur(12px);
  }

  @media (min-width: 768px) {
    .site-sidebar {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .site-sidebar {
      width: var(--layout-sidebar-desktop);
      padding-inline: 1.25rem;
      padding-block: 3rem;
    }
  }

  @media (min-width: 1280px) {
    .site-sidebar {
      width: var(--layout-sidebar-wide);
      padding-inline: 1.5rem;
    }
  }

  .mobile-topbar {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
